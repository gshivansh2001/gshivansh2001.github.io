@unpublished{gupta_genai_opensource,
  title     = {The Generative AI Dilemma: Enhancing Productivity while Managing Technical Debt in Open Source Development},
  author    = {Gupta, Shivansh and Sharma, Vasundhara and Karanam, Aditya},
  year      = {2026},
  note      = {Work in progress},
  abstract =  {This paper investigates the behavioral consequences of generative AI adoption in open-source software development. Using large-scale observational data, it studies how AI-assisted coding alters developer sorting across projects, the match between expertise and task requirements, and patterns of contribution. The findings aim to shed light on how AI tools reshape incentives, coordination, and long-term project sustainability.},
  selected  = {true}
}

@unpublished{gupta_ai_disclosure,
  title     = {Examining Effects of AI Disclosure on Early-Stage Ventures},
  author    = {Gupta, Shivansh and Sharma, Vasundhara and Gayatri, Aketi},
  year      = {2026},
  note      = {Work in progress},
  abstract =  {This paper studies how transparency about artificial intelligence reshapes market behavior in creative funding contexts. Using a platform-level policy change as a source of exogenous variation, we show that mandatory AI disclosure leads to significant declines in funding outcomes. We argue that disclosure activates a multi-channel devaluation process, wherein perceptions of reduced human effort, diminished authenticity, and heightened skepticism jointly suppress support. By linking causal estimates with discourse-based evidence, the study highlights how transparency can trigger adverse belief formation in environments where value is closely tied to human authorship.},
  selected  = {true}
}

